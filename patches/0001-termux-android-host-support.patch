--- a/packages/flutter_tools/lib/src/base/platform.dart
+++ b/packages/flutter_tools/lib/src/base/platform.dart
@@ -31,6 +31,10 @@ abstract class Platform {
   /// True if the operating system is Linux.
   bool get isLinux => operatingSystem == 'linux';
 
+  /// True if the operating system uses the Linux userspace conventions that
+  /// the Flutter tool relies on for host-side artifacts and paths.
